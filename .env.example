PORT=3000
GITHUB_TOKEN=your_github_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
ALIBABA_CLOUD_API_KEY=your_alibaba_key_here
OPENROUTER_API_KEY=your_openrouter_key_here
LLM_API_KEY=your_llm_api_key_here
PUBLIC_BASE_URL=https://your-backend-url.azurewebsites.net
STORAGE_DIR=generated

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
ADMIN_EMAIL=your-email@example.com

# OAuth Providers
GITHUB_OAUTH_CLIENT_ID=your_github_oauth_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_github_oauth_client_secret

GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret

MICROSOFT_OAUTH_CLIENT_ID=your_microsoft_oauth_client_id
MICROSOFT_OAUTH_CLIENT_SECRET=your_microsoft_oauth_client_secret
MICROSOFT_OAUTH_TENANT=common
